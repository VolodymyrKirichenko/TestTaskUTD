{
  "version": 2,
  "ignoreCommand": "git diff --quiet HEAD^ HEAD -- packages/server packages/shared",
  "builds": [
    {
      "src": "packages/server/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "packages/server/api/index.ts"
    }
  ]
}
